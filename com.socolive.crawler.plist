<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.socolive.crawler</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/phu.nb/workspaces/codes/socolive-crawler/deploy.sh</string>
    </array>

    <!-- run every 5 minutes, and once right after load/login -->
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/phu.nb/workspaces/codes/socolive-crawler</string>

    <key>StandardOutPath</key>
    <string>/Users/phu.nb/workspaces/codes/socolive-crawler/deploy.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/phu.nb/workspaces/codes/socolive-crawler/deploy.log</string>
</dict>
</plist>
